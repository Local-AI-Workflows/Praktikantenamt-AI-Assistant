# =====================================================================
# Multi-Model Benchmark Runner — Environment Variables
# =====================================================================
# Copy this file to .env and fill in your credentials.
# The .env file is gitignored; this .env.example is committed.

# --- API Keys ---
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- Ollama Endpoint Override (optional) ---
# Overrides the endpoint in benchmark_config.yaml for all Ollama models.
# Leave unset to use the value from benchmark_config.yaml.
OLLAMA_ENDPOINT=http://gpu-server01.ios.htwg-konstanz.de:11434
